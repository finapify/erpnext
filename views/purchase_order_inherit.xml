<odoo>
    <record id="purchase_order_form_inherit_finapify" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.finapify</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_finapify_pay" type="object" string="Pay with Finapify"
                        class="btn-primary"
                        attrs="{'invisible': [('state', 'not in', ('purchase', 'done'))]}"/>
            </xpath>
        </field>
    </record>
</odoo>
