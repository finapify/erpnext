<odoo>
    <record id="view_finapify_connection_tree" model="ir.ui.view">
        <field name="name">finapify.connection.tree</field>
        <field name="model">finapify.connection</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="default_source_bank_id"/>
                <field name="last_sync_at"/>
            </tree>
        </field>
    </record>

    <record id="view_finapify_connection_form" model="ir.ui.view">
        <field name="name">finapify.connection.form</field>
        <field name="model">finapify.connection</field>
        <field name="arch" type="xml">
            <form string="Finapify Connection">
                <sheet>
                    <header>
                        <button name="%(action_finapify_connect_wizard)d" type="action" string="Connect" class="btn-primary" attrs="{'invisible':[('state','=','connected')]}"/>
                        <button name="action_disconnect" type="object" string="Disconnect" class="btn-secondary" attrs="{'invisible':[('state','!=','connected')]}"/>
                        <button name="action_refresh_accounts" type="object" string="Refresh Accounts" class="btn-secondary" attrs="{'invisible':[('state','!=','connected')]}"/>
                        <field name="state" widget="statusbar" statusbar_visible="disconnected,connected,error"/>
                    </header>

                    <group>
                        <group>
                            <field name="company_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="consent_id" readonly="1"/>
                            <field name="default_source_bank_id" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="is_connected" readonly="1"/>
                            <field name="error_message" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Linked Accounts">
                            <field name="bank_accounts_json" nolabel="1" widget="text" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_finapify_connection" model="ir.actions.act_window">
        <field name="name">Finapify Connection</field>
        <field name="res_model">finapify.connection</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[("company_id","=",current_company_id),("user_id","=",uid)]</field>
    </record>
</odoo>
