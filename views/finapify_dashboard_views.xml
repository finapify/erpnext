<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Finapify Dashboard Action -->
    <record id="action_finapify_dashboard" model="ir.actions.act_window">
        <field name="name">Finapify Dashboard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">finapify.dashboard</field>
        <field name="view_mode">form</field>
        <field name="views">[(False, 'form')]</field>
        <field name="target">main</field>
    </record>

    <!-- Finapify Dashboard Form View -->
    <record id="finapify_dashboard_view_form" model="ir.ui.view">
        <field name="name">finapify.dashboard.form</field>
        <field name="model">finapify.dashboard</field>
        <field name="arch" type="xml">
            <form string="Finapify Dashboard" create="false" edit="false" delete="false">
                <link rel="stylesheet" href="/finapify_payments/static/css/finapify_dashboard.css"/>
                <script type="text/javascript" src="/finapify_payments/static/js/finapify_dashboard.js"/>
                
                <div class="o_dashboard_container">
                    <!-- Dashboard Header -->
                    <div class="o_dashboard_header">
                        <h1 class="o_page_title">
                            <i class="fa fa-dashboard"/> Finapify Payment Hub
                        </h1>
                        <p class="text-muted">Manage your Finapify payment integrations and transactions</p>
                    </div>

                    <!-- Quick Stats Section -->
                    <div class="row mt-4 mb-4">
                        <div class="col-md-4">
                            <div class="card bg-light border-left-primary">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-auto">
                                            <i class="fa fa-link fa-2x text-primary"></i>
                                        </div>
                                        <div class="col">
                                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Active Connections</div>
                                            <div class="h3 mb-0"><span class="finapify-stat-connections">0</span></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-light border-left-warning">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-auto">
                                            <i class="fa fa-hourglass-half fa-2x text-warning"></i>
                                        </div>
                                        <div class="col">
                                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Pending Requests</div>
                                            <div class="h3 mb-0"><span class="finapify-stat-pending">0</span></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-light border-left-success">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-auto">
                                            <i class="fa fa-check-circle fa-2x text-success"></i>
                                        </div>
                                        <div class="col">
                                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Completed Batches</div>
                                            <div class="h3 mb-0"><span class="finapify-stat-completed">0</span></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Links Section -->
                    <div class="row">
                        <div class="col-12">
                            <h2 class="text-uppercase o_section_title">Quick Links</h2>
                        </div>
                    </div>

                    <!-- Connection Management -->
                    <div class="row mt-3">
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card dashboard-card hover-shadow" data-action="action_finapify_connection">
                                <div class="card-body p-4 text-center">
                                    <i class="fa fa-link fa-3x text-primary mb-3"></i>
                                    <h5 class="card-title">
                                        <a href="#" onclick="return false;">
                                            Finapify Connection
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        Manage Finapify API connections and authentication
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-primary w-100" data-action="action_finapify_connection">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Payment Requests -->
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card dashboard-card hover-shadow" data-action="action_finapify_payment_request">
                                <div class="card-body p-4 text-center">
                                    <i class="fa fa-paper-plane fa-3x text-info mb-3"></i>
                                    <h5 class="card-title">
                                        <a href="#" onclick="return false;">
                                            Payment Requests
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        Create and manage individual payment requests
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-info w-100" data-action="action_finapify_payment_request">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Payment Batches -->
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card dashboard-card hover-shadow" data-action="action_finapify_payment_batch">
                                <div class="card-body p-4 text-center">
                                    <i class="fa fa-credit-card fa-3x text-success mb-3"></i>
                                    <h5 class="card-title">
                                        <a href="#" onclick="return false;">
                                            Payment Batches
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        Manage bulk payment batches and track progress
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-success w-100" data-action="action_finapify_payment_batch">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Configuration Section -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <h2 class="text-uppercase o_section_title">Configuration</h2>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <!-- Vendor Bank Mapping -->
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card dashboard-card hover-shadow" data-action="action_finapify_vendor_bank_map">
                                <div class="card-body p-4 text-center">
                                    <i class="fa fa-building fa-3x text-warning mb-3"></i>
                                    <h5 class="card-title">
                                        <a href="#" onclick="return false;">
                                            Vendor Bank Mapping
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        Map vendors to their bank accounts
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-warning w-100" data-action="action_finapify_vendor_bank_map">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Journal Mapping -->
                        <div class="col-md-6 col-lg-4 mb-3">
