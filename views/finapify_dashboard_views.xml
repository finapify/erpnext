                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-danger w-100" data-action="action_finapify_journal_map">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Reconciliation Center -->
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card dashboard-card hover-shadow" data-action="action_finapify_reconciliation">
                                <div class="card-body p-4 text-center">
                                    <i class="fa fa-balance-scale fa-3x text-secondary mb-3"></i>
                                    <h5 class="card-title">
                                        <a href="#" onclick="return false;">
                                            Reconciliation Center
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        Reconcile payments with invoices
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-secondary w-100" data-action="action_finapify_reconciliation">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Audit &amp; Support Section -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <h2 class="text-uppercase o_section_title">Audit &amp; Support</h2>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <!-- Logs &amp; Audit -->
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card dashboard-card hover-shadow" data-action="action_finapify_log">
                                <div class="card-body p-4 text-center">
                                    <i class="fa fa-history fa-3x text-dark mb-3"></i>
                                    <h5 class="card-title">
                                        <a href="#" onclick="return false;">
                                            Logs &amp; Audit Trail
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        View system logs, audit trail, and debug information
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-dark w-100" data-action="action_finapify_log">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Settings -->
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card dashboard-card hover-shadow">
                                <div class="card-body p-4 text-center">
                                    <i class="fa fa-cog fa-3x text-muted mb-3"></i>
                                    <h5 class="card-title">
                                        <a href="#" onclick="return false;">
                                            Settings
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        Configure Finapify API keys and webhooks
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-muted w-100" onclick="window.location.href='/web#action=base.action_res_config_settings';">
                                        <i class="fa fa-arrow-right"/> Open
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Help Section -->
                    <div class="row mt-5 pt-4 border-top">
                        <div class="col-12">
                            <div class="alert alert-info" role="alert">
                                <i class="fa fa-info-circle"/> <strong>Quick Tips:</strong>
                                <ul class="mb-0 mt-2">
                                    <li>Start by setting up your <strong>Finapify Connection</strong> with your API credentials</li>
                                    <li>Configure <strong>Vendor Bank Mapping</strong> to match vendors with bank accounts</li>
                                    <li>Set up <strong>Journal Mapping</strong> for proper accounting entries</li>
                                    <li>Create <strong>Payment Requests</strong> or <strong>Payment Batches</strong> to initiate payments</li>
                                    <li>Use <strong>Reconciliation Center</strong> to match payments with invoices</li>
                                    <li>Check <strong>Logs &amp; Audit Trail</strong> for transaction history and debugging</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </field>
    </record>

