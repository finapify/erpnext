<odoo>
    <record id="view_partner_form_inherit_finapify" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.finapify</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="action" name="%(action_finapify_vendor_bank_map)d" class="oe_stat_button" icon="fa-bank"
                        attrs="{'invisible':[('supplier_rank','<=',0)]}">
                    <field string="Finapify Bank" name="finapify_vendor_bank_map_id" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
