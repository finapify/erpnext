<odoo>
    <record id="view_finapify_payment_request_tree" model="ir.ui.view">
        <field name="name">finapify.payment.request.tree</field>
        <field name="model">finapify.payment.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="vendor_bill_id"/>
                <field name="vendor_id"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="source_bank_id"/>
                <field name="status"/>
                <field name="reconciliation_status"/>
            </tree>
        </field>
    </record>

    <record id="view_finapify_payment_request_form" model="ir.ui.view">
        <field name="name">finapify.payment.request.form</field>
        <field name="model">finapify.payment.request</field>
        <field name="arch" type="xml">
            <form string="Payment Request">
                <sheet>
                    <header>
                        <button name="action_retry" type="object" string="Retry" class="btn-secondary" attrs="{'invisible':[('status','not in',('failed','processing'))]}"/>
                        <button name="action_retry_reconcile" type="object" string="Retry Reconcile" class="btn-secondary" attrs="{'invisible':[('status','!=','success')]}"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,otp_pending,submitted,processing,success,failed"/>
                    </header>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="vendor_bill_id" readonly="1"/>
                            <field name="vendor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="source_bank_id" readonly="1"/>
                            <field name="vendor_bank_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="correlation_id" readonly="1"/>
                            <field name="idempotency_key" readonly="1"/>
                            <field name="n8n_request_id" readonly="1"/>
                            <field name="finapify_ref" readonly="1"/>
                        </group>
                        <group>
                            <field name="reconciliation_status" readonly="1"/>
                            <field name="attempts" readonly="1"/>
                            <field name="last_error" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payments">
                            <field name="created_payment_ids" nolabel="1"/>
                        </page>
                        <page string="Request Payload">
                            <field name="request_payload_json" nolabel="1" widget="text" readonly="1"/>
                        </page>
                        <page string="Response Payload">
                            <field name="response_payload_json" nolabel="1" widget="text" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_finapify_payment_request" model="ir.actions.act_window">
        <field name="name">Payment Requests</field>
        <field name="res_model">finapify.payment.request</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
