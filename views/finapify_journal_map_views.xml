<odoo>
    <record id="view_finapify_journal_map_tree" model="ir.ui.view">
        <field name="name">finapify.journal.map.tree</field>
        <field name="model">finapify.journal.map</field>
        <field name="arch" type="xml">
            <tree>
                <field name="company_id"/>
                <field name="finapify_source_bank_id"/>
                <field name="journal_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_finapify_journal_map_form" model="ir.ui.view">
        <field name="name">finapify.journal.map.form</field>
        <field name="model">finapify.journal.map</field>
        <field name="arch" type="xml">
            <form string="Journal Mapping">
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="finapify_source_bank_id"/>
                        <field name="journal_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_finapify_journal_map" model="ir.actions.act_window">
        <field name="name">Journal Mapping</field>
        <field name="res_model">finapify.journal.map</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
</odoo>
