<odoo>
    <record id="view_move_form_inherit_finapify" model="ir.ui.view">
        <field name="name">account.move.form.inherit.finapify</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_finapify_pay" type="object" string="Pay with Finapify"
                        class="btn-primary"
                        attrs="{'invisible':[('move_type','not in',('in_invoice','in_refund')),('state','not in',('draft','posted'))]}"/>
            </xpath>
            <xpath expr="//sheet//group" position="after">
                <group attrs="{'invisible':[('move_type','not in',('in_invoice','in_refund'))]}">
                    <group>
                        <field name="finapify_vendor_bank_id" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
