<odoo>
    <record id="view_finapify_pay_bulk_wizard_form" model="ir.ui.view">
        <field name="name">finapify.pay.bulk.wizard.form</field>
        <field name="model">finapify.pay.bulk.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Pay with Finapify">
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="mode"/>
                        <field name="source_bank_id" attrs="{'required':[('mode','=','one_bank')]}"/>
                        <field name="bill_ids" widget="many2many_tags" readonly="1"/>
                        <field name="otp" placeholder="Enter OTP"/>
                    </group>
                    <footer>
                        <button string="Pay" type="object" name="action_pay_bulk" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_finapify_pay_bulk_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Pay with Finapify</field>
        <field name="res_model">finapify.pay.bulk.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
