<odoo>
    <record id="view_finapify_connect_wizard_form" model="ir.ui.view">
        <field name="name">finapify.connect.wizard.form</field>
        <field name="model">finapify.connect.wizard</field>
        <field name="arch" type="xml">
            <form string="Connect Finapify">
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="supabase_jwt" placeholder="Paste Supabase JWT"/>
                        <field name="consent_id"/>
                        <field name="default_source_bank_id"/>
                        <field name="bank_accounts_json" widget="text"/>
                    </group>
                    <footer>
                        <button string="Connect" type="object" name="action_connect" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_finapify_connect_wizard" model="ir.actions.act_window">
        <field name="name">Connect Finapify</field>
        <field name="res_model">finapify.connect.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
